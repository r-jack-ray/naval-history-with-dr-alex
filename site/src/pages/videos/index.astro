---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Videos | Naval History with Dr. Alex Archive"
  description="Browse Naval History with Dr. Alex video records and curated segment notes."
  pageType="video-index"
>
  <main class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Videos</p>
      <h1>Video records will land here first.</h1>
      <p class="lede">
        The next implementation phase will render one structured video prototype from the channel
        inventory before expanding into generated pages.
      </p>
    </section>

    <section class="empty-state">
      <span class="label">Next phase</span>
      <h2>Prototype one source video</h2>
      <p>
        This page is ready for `src/channel/episodes.json` data and segment-first content entries.
      </p>
    </section>
  </main>
</BaseLayout>

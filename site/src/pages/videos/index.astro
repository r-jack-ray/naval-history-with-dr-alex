---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { prototypeVideos } from "../../data/prototype-video";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Videos | Naval History with Dr. Alex Archive"
  description="Browse Naval History with Dr. Alex video records and curated segment notes."
  pageType="video-index"
>
  <main class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Videos</p>
      <h1>Prototype video records.</h1>
      <p class="lede">
        This first pass renders one structured record from the channel inventory before expanding
        into generated pages.
      </p>
    </section>

    <section class="video-card-grid" aria-label="Prototype video records">
      {
        prototypeVideos.map((video) => (
          <article class="video-card">
            <a href={`${baseUrl}videos/${video.slug}/`}>
              <img
                src={video.thumbnailUrl}
                alt={`Thumbnail for ${video.title}`}
                loading="lazy"
                width="480"
                height="270"
              />
              <div>
                <span class="label">{video.sourceType}</span>
                <h2>{video.title}</h2>
                <p>
                  {video.publishedLabel} · {video.durationLabel} · {video.viewCountLabel}
                </p>
              </div>
            </a>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveVideos } from "../../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Videos | Naval History with Dr. Alex Archive"
  description="Browse Naval History with Dr. Alex video records and curated segment notes."
  pageType="video-index"
>
  <main id="content" class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Videos</p>
      <h1>Video records.</h1>
      <p class="lede">
        Browse Dr. Alex Clarke videos with source metadata, transcript status, topics, and
        curated segment links.
      </p>
    </section>

    <section class="video-card-grid" aria-label="Video records">
      {
        archiveVideos.map((video) => (
          <article class="video-card">
            <a href={`${baseUrl}videos/${video.slug}/`}>
              <img
                src={video.thumbnailUrl}
                alt={`Thumbnail for ${video.title}`}
                loading="lazy"
                width="480"
                height="270"
              />
              <div>
                <span class="label">{video.sourceType}</span>
                <h2>{video.title}</h2>
                <p>
                  {video.publishedLabel} · {video.durationLabel} · {video.segmentSlugs.length} segments
                </p>
                <div class="topic-row compact" aria-label="Topics">
                  {video.topics.slice(0, 4).map((topic) => <span>{topic.title}</span>)}
                  {video.topics.length > 4 && <span>+{video.topics.length - 4}</span>}
                </div>
              </div>
            </a>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

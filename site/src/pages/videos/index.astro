---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveVideos } from "../../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const timeNoteCountLabel = (count: number) => count === 1 ? "1 time note" : `${count} time notes`;
const videosByPublishDate = [...archiveVideos].sort((left, right) => {
  const leftTimestamp = left.publishedAt == null ? Number.NEGATIVE_INFINITY : Date.parse(left.publishedAt);
  const rightTimestamp = right.publishedAt == null ? Number.NEGATIVE_INFINITY : Date.parse(right.publishedAt);

  return rightTimestamp - leftTimestamp || left.title.localeCompare(right.title);
});
---

<BaseLayout
  title="Video Guides | Naval History with Dr. Alex Study Guide"
  description="Browse Dr. Alex Clarke video guides by subject and time note."
  pageType="video-index"
>
  <main id="content" class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Videos</p>
      <h1>Video guides.</h1>
      <p class="lede">
        Start from a Dr. Clarke video, scan the subjects it covers, then jump to
        the part that matches what you want to learn.
      </p>
    </section>

    <section class="video-card-grid" aria-label="Videos">
      {
        videosByPublishDate.map((video) => (
          <article class="video-card">
            <a href={`${baseUrl}videos/${video.slug}/`}>
              <img
                src={video.thumbnailUrl}
                alt={`Thumbnail for ${video.title}`}
                loading="lazy"
                width="640"
                height="360"
              />
              <div>
                <span class="label">{video.sourceType}</span>
                <h2>{video.title}</h2>
                <p>
                  {video.publishedLabel} · {video.durationLabel} · {timeNoteCountLabel(video.segmentSlugs.length)}
                </p>
                <div class="topic-row compact" aria-label="Topics">
                  {video.topics.slice(0, 4).map((topic) => <span>{topic.title}</span>)}
                  {video.topics.length > 4 && <span>+{video.topics.length - 4}</span>}
                </div>
              </div>
            </a>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

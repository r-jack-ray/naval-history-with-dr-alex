---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getVideoPaths,
  segmentsForVideo,
  type ArchiveVideo,
} from "../../data/archive";
import { buildVideoPageMetadata } from "../../../../src/site/page-metadata.js";

export function getStaticPaths() {
  return getVideoPaths();
}

const { video } = Astro.props as { video: ArchiveVideo };
const segments = segmentsForVideo(video);
const metadata = buildVideoPageMetadata(video);
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const formatVideoKind = (videoKind: ArchiveVideo["videoKind"]) => videoKind === "stream" ? "Stream" : "Video";
const timeNoteCountLabel = (count: number) => count === 1 ? "1 time note" : `${count} time notes`;
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  pageType="video"
  socialType="video.other"
  socialImageUrl={video.thumbnailUrl}
  socialImageAlt={`Thumbnail for ${video.title}`}
>
  <Fragment slot="head">
    <meta data-pagefind-meta="video[content]" content={video.title} />
    <meta data-pagefind-meta="videoId[content]" content={video.videoId} />
    <meta data-pagefind-meta="videoDateAt[content]" content={video.videoDateAt} />
    <meta data-pagefind-meta="videoDateLabel[content]" content={video.videoDateLabel} />
    <meta data-pagefind-filter="video[content]" content={video.title} />
    {video.topics.map((topic) => <meta data-pagefind-filter="topic[content]" content={topic.title} />)}
  </Fragment>

  <main id="content" class="video-page" data-pagefind-body>
    <section class="video-hero">
      <div class="video-hero-copy">
        <p class="eyebrow">Video</p>
        <h1>{video.title}</h1>
        <div class="topic-row" aria-label="Topics">
          {video.topics.map((topic) => <a href={`${baseUrl}topics/${topic.slug}/`}>{topic.title}</a>)}
        </div>
        <p class="lede">
          A video guide to the naval history, strategy, technology, and institutions
          covered in this Dr. Clarke video.
        </p>
        <div class="action-row">
          <a class="primary-link" href={video.youtubeUrl}>Watch on YouTube</a>
          <a class="secondary-link" href="#segments">View time notes</a>
        </div>
      </div>

      <div class="video-media">
        <iframe
          src={video.embedUrl}
          title={video.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </section>

    <section class="detail-grid" aria-label="Video overview">
      <article>
        <span class="label">Date</span>
        <strong><time datetime={video.videoDateAt}>{video.videoDateLabel}</time></strong>
      </article>
      <article>
        <span class="label">Runtime</span>
        <strong>{video.durationLabel}</strong>
      </article>
      <article>
        <span class="label">Format</span>
        <strong>{formatVideoKind(video.videoKind)}</strong>
      </article>
      <article>
        <span class="label">Guide points</span>
        <strong>{timeNoteCountLabel(segments.length)}</strong>
      </article>
    </section>

    <section id="segments" class="video-details">
      <div>
        <h2>Time notes</h2>
        <ol class="segment-list">
          {
            segments.map((segment) => (
              <li>
                <a href={`${baseUrl}segments/${segment.slug}/`}>
                  <span>{segment.start}</span>
                  <div>
                    {segment.kind === "qa" && segment.question && segment.answerShort ? (
                      <>
                        <span class="qa-field-label">Question</span>
                        <strong>{segment.question}</strong>
                        <span class="qa-field-label answer-label">Answer</span>
                        <p>{segment.answerShort}</p>
                      </>
                    ) : (
                      <>
                        <strong>{segment.title}</strong>
                        <p>{segment.summary}</p>
                      </>
                    )}
                  </div>
                  <small>{segment.kindLabel}</small>
                </a>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getVideoPaths,
  segmentsForVideo,
  type ArchiveVideo,
} from "../../data/archive";

export function getStaticPaths() {
  return getVideoPaths();
}

const { video } = Astro.props as { video: ArchiveVideo };
const segments = segmentsForVideo(video);
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title={`${video.title} | Naval History with Dr. Alex Archive`}
  description={`Prototype archive page for ${video.title}.`}
  pageType="video"
>
  <Fragment slot="head">
    <meta data-pagefind-meta="video[content]" content={video.title} />
    <meta data-pagefind-meta="videoId[content]" content={video.videoId} />
    <meta data-pagefind-filter="video[content]" content={video.title} />
    {video.topics.map((topic) => <meta data-pagefind-filter="topic[content]" content={topic.title} />)}
  </Fragment>

  <main class="video-page" data-pagefind-body>
    <section class="video-hero">
      <div class="video-hero-copy">
        <p class="eyebrow">Prototype Video Record</p>
        <h1>{video.title}</h1>
        <div class="topic-row" aria-label="Topics">
          {video.topics.map((topic) => <a href={`${baseUrl}topics/${topic.slug}/`}>{topic.title}</a>)}
        </div>
        <p class="lede">
          Source-backed page using the channel inventory, YouTube metadata store, and curated
          segment seed. Segment links below are independently addressable archive entries.
        </p>
        <div class="action-row">
          <a class="primary-link" href={video.youtubeUrl}>Watch on YouTube</a>
          <a class="secondary-link" href="#segments">View segments</a>
        </div>
      </div>

      <div class="video-media">
        <iframe
          src={video.embedUrl}
          title={video.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </section>

    <section class="detail-grid" aria-label="Video metadata">
      <article>
        <span class="label">Published</span>
        <strong>{video.publishedLabel}</strong>
      </article>
      <article>
        <span class="label">Duration</span>
        <strong>{video.durationLabel}</strong>
      </article>
      <article>
        <span class="label">Source type</span>
        <strong>{video.sourceType}</strong>
      </article>
      <article>
        <span class="label">Transcript</span>
        <strong>{video.transcriptStatus}</strong>
      </article>
    </section>

    <section class="video-details">
      <div>
        <h2>Source metadata</h2>
        <dl class="metadata-list">
          <div>
            <dt>Video ID</dt>
            <dd>{video.videoId}</dd>
          </div>
          <div>
            <dt>Inventory stem</dt>
            <dd>{video.fileStem}</dd>
          </div>
          <div>
            <dt>Views</dt>
            <dd>{video.stats.views ?? video.viewCountLabel}</dd>
          </div>
          <div>
            <dt>Likes</dt>
            <dd>{video.stats.likes ?? "Unavailable"}</dd>
          </div>
          <div>
            <dt>Comments</dt>
            <dd>{video.stats.comments ?? "Unavailable"}</dd>
          </div>
        </dl>
      </div>

      <div id="segments">
        <h2>Curated segments</h2>
        <ol class="segment-list">
          {
            segments.map((segment) => (
              <li>
                <a href={`${baseUrl}segments/${segment.slug}/`}>
                  <span>{segment.start}</span>
                  <strong>{segment.title}</strong>
                  <small>{segment.kindLabel}</small>
                </a>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>

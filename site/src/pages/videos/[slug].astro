---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getVideoPaths,
  segmentsForVideo,
  type ArchiveVideo,
} from "../../data/archive";

export function getStaticPaths() {
  return getVideoPaths();
}

const { video } = Astro.props as { video: ArchiveVideo };
const segments = segmentsForVideo(video);
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const formatSourceType = (sourceType: string) => sourceType === "stream" ? "Stream" : "Video";
const timestampCountLabel = (count: number) => count === 1 ? "1 timestamp" : `${count} timestamps`;
---

<BaseLayout
  title={`${video.title} | Naval History with Dr. Alex Study Guide`}
  description={`${video.title} timestamp guide for learning naval history with Dr. Alex Clarke.`}
  pageType="video"
>
  <Fragment slot="head">
    <meta data-pagefind-meta="video[content]" content={video.title} />
    <meta data-pagefind-meta="videoId[content]" content={video.videoId} />
    <meta data-pagefind-filter="video[content]" content={video.title} />
    {video.topics.map((topic) => <meta data-pagefind-filter="topic[content]" content={topic.title} />)}
  </Fragment>

  <main id="content" class="video-page" data-pagefind-body>
    <section class="video-hero">
      <div class="video-hero-copy">
        <p class="eyebrow">Video</p>
        <h1>{video.title}</h1>
        <div class="topic-row" aria-label="Topics">
          {video.topics.map((topic) => <a href={`${baseUrl}topics/${topic.slug}/`}>{topic.title}</a>)}
        </div>
        <p class="lede">
          A timestamp guide to the naval history, strategy, technology, and institutions
          covered in this Dr. Clarke video.
        </p>
        <div class="action-row">
          <a class="primary-link" href={video.youtubeUrl}>Watch on YouTube</a>
          <a class="secondary-link" href="#segments">View timestamps</a>
        </div>
      </div>

      <div class="video-media">
        <iframe
          src={video.embedUrl}
          title={video.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </section>

    <section class="detail-grid" aria-label="Video overview">
      <article>
        <span class="label">Published</span>
        <strong>{video.publishedLabel}</strong>
      </article>
      <article>
        <span class="label">Runtime</span>
        <strong>{video.durationLabel}</strong>
      </article>
      <article>
        <span class="label">Format</span>
        <strong>{formatSourceType(video.sourceType)}</strong>
      </article>
      <article>
        <span class="label">Guide points</span>
        <strong>{timestampCountLabel(segments.length)}</strong>
      </article>
    </section>

    <section id="segments" class="video-details">
      <div>
        <h2>Timestamp guide</h2>
        <ol class="segment-list">
          {
            segments.map((segment) => (
              <li>
                <a href={`${baseUrl}segments/${segment.slug}/`}>
                  <span>{segment.start}</span>
                  <div>
                    <strong>{segment.title}</strong>
                    <p>{segment.summary}</p>
                  </div>
                  <small>{segment.kindLabel}</small>
                </a>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>

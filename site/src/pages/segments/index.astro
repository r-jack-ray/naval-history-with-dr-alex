---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveSegments } from "../../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Time Notes | Naval History with Dr. Alex Study Guide"
  description="Browse focused learning notes from Dr. Alex Clarke videos."
  pageType="segment-index"
>
  <main id="content" class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Time notes</p>
      <h1>Time notes.</h1>
      <p class="lede">
        Focused summaries point to moments where Dr. Clarke explains ships, navies,
        battles, technology, strategy, and audience questions.
      </p>
    </section>

    <section class="record-grid" aria-label="Segments">
      {
        archiveSegments.map((segment) => (
          <article class="segment-card">
            <span class="label">{segment.kindLabel} · {segment.start}</span>
            <h2><a href={`${baseUrl}segments/${segment.slug}/`}>{segment.title}</a></h2>
            <p>{segment.summary}</p>
            <div class="topic-row compact" aria-label="Topics">
              {segment.topics.map((topic) => <a href={`${baseUrl}topics/${topic.slug}/`}>{topic.title}</a>)}
            </div>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

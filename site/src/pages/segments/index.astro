---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveTopics } from "../../data/archive";
import timeNotesFinderUrl from "../../scripts/time-notes-finder.js?url";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const starterTopics = [...archiveTopics]
  .sort((left, right) => right.segmentCount - left.segmentCount || right.videoCount - left.videoCount)
  .slice(0, 8);
---

<BaseLayout
  title="Find Time Notes | Naval History with Dr. Alex Study Guide"
  description="Find a worthwhile Dr. Alex Clarke video moment by naval subject and explanation type."
  pageType="segment-index"
>
  <Fragment slot="head">
    <script src={timeNotesFinderUrl} defer is:inline></script>
  </Fragment>

  <main id="content" class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Time Notes</p>
      <h1>Find a useful moment to watch.</h1>
      <p class="lede">
        Search a naval subject, then choose focused explanations or audience Q&amp;A.
        Every result tells you what Dr. Clarke covers before you open the video.
      </p>
    </section>

    <section class="search-panel search-experience time-notes-finder" aria-label="Time Notes finder">
      <form
        class="search-controls time-notes-finder-form"
        role="search"
        data-time-notes-form
        data-pagefind-url={`${baseUrl}pagefind/pagefind.js`}
        data-pagefind-base={`${baseUrl}pagefind/`}
        data-site-base={baseUrl}
      >
        <div class="search-control">
          <label for="time-notes-query">Search time notes by subject</label>
          <div class="search-input-shell">
            <input
              class="search-input"
              id="time-notes-query"
              type="search"
              name="q"
              placeholder="Try destroyers, Jutland, logistics, radar, or Royal Navy"
              autocomplete="off"
              aria-controls="time-notes-results"
              aria-describedby="time-notes-help time-notes-status"
              data-time-notes-query
            />
            <button class="search-clear-button" type="button" data-time-notes-clear hidden>Clear</button>
          </div>
          <p class="search-help" id="time-notes-help">
            Use a ship, class, navy, battle, weapon, person, policy, doctrine, or other naval idea.
          </p>
        </div>

        <fieldset class="time-notes-modes" data-time-notes-modes>
          <legend>Show</legend>
          <label>
            <input type="radio" name="mode" value="all" checked />
            <span><strong>All time notes</strong><small>Explanations and Q&amp;A</small></span>
          </label>
          <label>
            <input type="radio" name="mode" value="explanations" />
            <span><strong>Explanations</strong><small>Chapters and notable points</small></span>
          </label>
          <label>
            <input type="radio" name="mode" value="qa" />
            <span><strong>Q&amp;A</strong><small>Audience questions and answers</small></span>
          </label>
        </fieldset>
      </form>

      <p class="search-status search-feedback" id="time-notes-status" data-time-notes-status aria-live="polite" aria-atomic="true">
        Enter a subject to find matching watch points.
      </p>

      <div class="time-notes-blank" data-time-notes-blank>
        <div>
          <p class="search-start-label">Popular subjects</p>
          <h2>Try a starting point</h2>
          <p>Choose a subject below or type your own to find precise moments to watch.</p>
        </div>
        <div class="topic-row compact" aria-label="Subject starting points">
          {starterTopics.map((topic) => (
            <a href={`${baseUrl}topics/${topic.slug}/`} data-time-notes-suggestion={topic.title}>
              {topic.title}
            </a>
          ))}
        </div>
        <a class="secondary-link" href={`${baseUrl}segments/browse/`}>Browse all time notes</a>
        <noscript>
          <p>JavaScript is required for the subject finder. Topic links and the complete time-notes archive remain available.</p>
        </noscript>
      </div>

      <div
        class="record-grid search-results time-notes-results"
        id="time-notes-results"
        data-time-notes-results
        aria-label="Time Notes results"
        aria-busy="false"
      ></div>
      <button class="show-more-button" type="button" data-time-notes-more hidden>Show more</button>
    </section>

    <section class="route-guidance" aria-labelledby="time-notes-next-heading">
      <p class="eyebrow">Other ways into the guide</p>
      <h2 id="time-notes-next-heading">Choose the route that matches your question.</h2>
      <div>
        <p><a href={`${baseUrl}videos/`}><strong>Video Guides</strong></a> help after you have selected a video.</p>
        <p><a href={`${baseUrl}topics/`}><strong>Topics</strong></a> follow one subject across multiple videos.</p>
        <p><a href={`${baseUrl}search/`}><strong>Search</strong></a> finds a known name or phrase across videos, topics, and time notes.</p>
        <p><a href={`${baseUrl}segments/browse/`}><strong>Browse all time notes</strong></a> opens the complete chronological directory.</p>
      </div>
    </section>
  </main>
</BaseLayout>

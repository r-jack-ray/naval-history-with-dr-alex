---
import BaseLayout from "../layouts/BaseLayout.astro";
import { archiveSegments, archiveTopics, archiveVideos } from "../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const prototypeVideo = archiveVideos[0];
const prototypeVideoUrl = `${baseUrl}videos/${prototypeVideo.slug}/`;
---

<BaseLayout
  title="Naval History with Dr. Alex Archive"
  description="Static reference archive for Naval History with Dr. Alex videos, segments, topics, and Q&A."
  pageType="home"
>
  <main data-pagefind-body>
    <section class="intro">
      <div class="intro-copy">
        <p class="eyebrow">Static Reference Archive</p>
        <h1>Video-first naval history notes, searchable by subject.</h1>
        <p class="lede">
          This archive will turn channel metadata, transcripts, and curated segment notes into a
          static website for browsing videos, ships, battles, navies, topics, and Q&A entries.
        </p>
      </div>

      <a class="feature-card" href={prototypeVideoUrl}>
        <img
          src={prototypeVideo.thumbnailUrl}
          alt={`Thumbnail for ${prototypeVideo.title}`}
          loading="lazy"
          width="480"
          height="360"
        />
        <div>
          <span>Prototype video page</span>
          <strong>{prototypeVideo.title}</strong>
        </div>
      </a>
    </section>

    <section class="status-grid" aria-label="Archive sections">
      <article>
        <span class="label">Videos</span>
        <h2>{archiveVideos.length} video page</h2>
        <p>Each page collects metadata, source links, transcript state, and curated segments.</p>
      </article>
      <article>
        <span class="label">Segments</span>
        <h2>{archiveSegments.length} timestamped chunks</h2>
        <p>Chapters, notable points, Q&A, and transcript excerpts stay distinct and searchable.</p>
      </article>
      <article>
        <span class="label">Topics</span>
        <h2>{archiveTopics.length} browsable topics</h2>
        <p>Topic pages collect related videos and segments without overbuilding taxonomy.</p>
      </article>
    </section>
  </main>
</BaseLayout>

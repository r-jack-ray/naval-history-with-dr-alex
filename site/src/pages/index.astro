---
import BaseLayout from "../layouts/BaseLayout.astro";
import { archiveSegments, archiveTopics, archiveVideos, compareVideosByDateDescending } from "../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const latestVideo = [...archiveVideos]
  .filter((video) => video.segmentSlugs.length > 0)
  .sort(compareVideosByDateDescending)[0];
const latestVideoUrl = `${baseUrl}videos/${latestVideo.slug}/`;
const featuredSegments = archiveSegments.slice(0, 4);
const activeTopics = [...archiveTopics]
  .sort((left, right) => right.segmentCount - left.segmentCount || right.videoCount - left.videoCount)
  .slice(0, 10);
---

<BaseLayout
  title="Naval History with Dr. Alex Study Guide"
  description="Search Dr. Alex Clarke videos by ship, battle, navy, doctrine, and the answer you want to find."
  pageType="home"
>
  <main id="content" class="home-page" data-pagefind-body>
    <section class="intro">
      <div class="intro-copy">
        <p class="eyebrow">Naval history study guide</p>
        <h1>Find the Dr. Clarke answer you're looking for.</h1>
        <p class="lede">
          Search ships, battles, weapons, navies, doctrine, and design tradeoffs,
          then jump straight to the moment he explains them.
        </p>
        <div class="action-row">
          <a class="primary-link" href={`${baseUrl}videos/`}>Browse video guides</a>
          <a class="secondary-link" href={`${baseUrl}search/`}>Search topics</a>
          <a class="secondary-link channel-link" href="https://www.youtube.com/@DrAlexClarke">
            Dr. Clarke's YouTube Channel
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <a class="feature-card" href={latestVideoUrl}>
        <img
          src={latestVideo.thumbnailUrl}
          alt={`Thumbnail for ${latestVideo.title}`}
          loading="lazy"
          width="640"
          height="360"
        />
        <div>
          <span>Latest video guide · <time datetime={latestVideo.videoDateAt}>{latestVideo.videoDateLabel}</time></span>
          <strong>{latestVideo.title}</strong>
        </div>
      </a>
    </section>

    <section class="status-grid" aria-label="Study guide sections">
      <a class="status-card" href={`${baseUrl}videos/`}>
        <span class="label">Videos</span>
        <h2>{archiveVideos.length} video guides</h2>
        <p>Start with an episode and scan the naval subjects it covers before opening YouTube.</p>
      </a>
      <a class="status-card" href={`${baseUrl}segments/`}>
        <span class="label">Time notes</span>
        <h2>{archiveSegments.length} time notes</h2>
        <p>Short summaries explain what Dr. Clarke covers at that moment and why it matters.</p>
      </a>
      <a class="status-card" href={`${baseUrl}topics/`}>
        <span class="label">Topics</span>
        <h2>{archiveTopics.length} topic paths</h2>
        <p>Follow ships, navies, battles, weapons, doctrine, and policy across related video moments.</p>
      </a>
    </section>

    <section class="home-section" aria-labelledby="featured-segments-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Time notes</p>
          <h2 id="featured-segments-heading">Featured watch points</h2>
        </div>
        <a class="secondary-link" href={`${baseUrl}segments/`}>Find time notes</a>
      </div>
      <div class="record-grid compact-grid">
        {
          featuredSegments.map((segment) => (
            <article class="segment-card">
              <span class="label">{segment.kindLabel} · {segment.start}</span>
              <h3><a href={`${baseUrl}segments/${segment.slug}/`}>{segment.title}</a></h3>
              <p>{segment.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="home-section" aria-labelledby="active-topics-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Topics</p>
          <h2 id="active-topics-heading">Active subject areas</h2>
        </div>
        <a class="secondary-link" href={`${baseUrl}topics/`}>All topics</a>
      </div>
      <div class="topic-cloud" aria-label="Active topics">
        {
          activeTopics.map((topic) => (
            <a href={`${baseUrl}topics/${topic.slug}/`}>
              <strong>{topic.title}</strong>
              <span>{topic.videoCount} videos · {topic.segmentCount} time notes</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

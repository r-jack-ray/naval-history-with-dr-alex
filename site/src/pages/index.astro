---
import BaseLayout from "../layouts/BaseLayout.astro";
import { archiveSegments, archiveTopics, archiveVideos } from "../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const featuredVideo = archiveVideos[0];
const featuredVideoUrl = `${baseUrl}videos/${featuredVideo.slug}/`;
const featuredSegments = archiveSegments.slice(0, 4);
const activeTopics = [...archiveTopics]
  .sort((left, right) => right.segmentCount - left.segmentCount || right.videoCount - left.videoCount)
  .slice(0, 10);
---

<BaseLayout
  title="Naval History with Dr. Alex Study Guide"
  description="Search Dr. Alex Clarke videos by naval history subject, topic, and timestamp."
  pageType="home"
>
  <main id="content" class="home-page" data-pagefind-body>
    <section class="intro">
      <div class="intro-copy">
        <p class="eyebrow">Learn how navies work</p>
        <h1>Naval history, organized around Dr. Clarke video timestamps.</h1>
        <p class="lede">
          Find the ships, battles, design choices, strategy questions, and naval institutions
          you want to understand, then jump straight to the relevant point in the video.
        </p>
        <div class="action-row">
          <a class="primary-link" href={`${baseUrl}videos/`}>Browse timestamp guides</a>
          <a class="secondary-link" href={`${baseUrl}search/`}>Search subjects</a>
        </div>
      </div>

      <a class="feature-card" href={featuredVideoUrl}>
        <img
          src={featuredVideo.thumbnailUrl}
          alt={`Thumbnail for ${featuredVideo.title}`}
          loading="lazy"
          width="480"
          height="360"
        />
        <div>
          <span>Featured timestamp guide</span>
          <strong>{featuredVideo.title}</strong>
        </div>
      </a>
    </section>

    <section class="status-grid" aria-label="Study guide sections">
      <article>
        <span class="label">Videos</span>
        <h2>{archiveVideos.length} video guides</h2>
        <p>Start from a Dr. Clarke episode and see the subjects it covers before opening YouTube.</p>
      </article>
      <article>
        <span class="label">Segments</span>
        <h2>{archiveSegments.length} timestamp pointers</h2>
        <p>Focused summaries explain what you will hear at a moment in the video and why it matters.</p>
      </article>
      <article>
        <span class="label">Topics</span>
        <h2>{archiveTopics.length} subject paths</h2>
        <p>Follow ships, navies, battles, weapons, doctrine, and policy across related timestamps.</p>
      </article>
    </section>

    <section class="home-section" aria-labelledby="featured-segments-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Segments</p>
          <h2 id="featured-segments-heading">Featured timestamp pointers</h2>
        </div>
        <a class="secondary-link" href={`${baseUrl}segments/`}>All timestamps</a>
      </div>
      <div class="record-grid compact-grid">
        {
          featuredSegments.map((segment) => (
            <article class="segment-card">
              <span class="label">{segment.kindLabel} · {segment.start}</span>
              <h3><a href={`${baseUrl}segments/${segment.slug}/`}>{segment.title}</a></h3>
              <p>{segment.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="home-section" aria-labelledby="active-topics-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Topics</p>
          <h2 id="active-topics-heading">Active subject areas</h2>
        </div>
        <a class="secondary-link" href={`${baseUrl}topics/`}>All topics</a>
      </div>
      <div class="topic-cloud" aria-label="Active topics">
        {
          activeTopics.map((topic) => (
            <a href={`${baseUrl}topics/${topic.slug}/`}>
              <strong>{topic.title}</strong>
              <span>{topic.videoCount} videos · {topic.segmentCount} segments</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

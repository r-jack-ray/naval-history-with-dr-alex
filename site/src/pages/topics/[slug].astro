---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  findVideoById,
  getTopicPaths,
  segmentsForTopic,
  videosForTopic,
  type ArchiveTopic,
} from "../../data/archive";

export function getStaticPaths() {
  return getTopicPaths();
}

const { topic } = Astro.props as { topic: ArchiveTopic };
const videos = videosForTopic(topic);
const segments = segmentsForTopic(topic);
const segmentEntries = segments.map((segment) => {
  const video = findVideoById(segment.videoId);
  if (video === undefined) {
    throw new Error(`Topic segment ${segment.slug} references missing video ${segment.videoId}.`);
  }
  return { segment, video };
});
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const timeNoteCountLabel = (count: number) => count === 1 ? "1 time note" : `${count} time notes`;
---

<BaseLayout
  title={`${topic.title} | Naval History with Dr. Alex Study Guide`}
  description={topic.summary}
  pageType="topic"
>
  <Fragment slot="head">
    <meta data-pagefind-meta="topic[content]" content={topic.title} />
    <meta data-pagefind-filter="topic[content]" content={topic.title} />
  </Fragment>

  <main id="content" class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Topic</p>
      <h1>{topic.title}</h1>
      <p class="lede">{topic.summary}</p>
      {topic.aliases.length > 0 && <p class="alias-line">Also searchable as {topic.aliases.join(", ")}.</p>}
    </section>

    <section class="content-grid">
      <article class="prose-panel">
        <h2>Related time notes</h2>
        <ol class="segment-list topic-segment-list">
          {
            segmentEntries.map(({ segment, video }) => (
              <li>
                <a href={`${baseUrl}segments/${segment.slug}/`}>
                  <div class="topic-segment-source">
                    <strong>{segment.videoTitle}</strong>
                    <time datetime={video.videoDateAt}>{video.videoDateLabel}</time>
                  </div>
                  <div class="topic-segment-note">
                    <span>{segment.start}</span>
                    <strong>{segment.title}</strong>
                    <small>{segment.kindLabel}</small>
                  </div>
                </a>
              </li>
            ))
          }
        </ol>
      </article>

      <aside class="source-panel">
        <h2>Video guides</h2>
        <ul class="small-card-list">
          {
            videos.map((video) => (
              <li>
                <a href={`${baseUrl}videos/${video.slug}/`}>
                  <strong>{video.title}</strong>
                  <span><time datetime={video.videoDateAt}>{video.videoDateLabel}</time> · {timeNoteCountLabel(video.segmentSlugs.length)}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </aside>
    </section>
  </main>
</BaseLayout>

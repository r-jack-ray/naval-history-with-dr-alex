---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Topics | Naval History with Dr. Alex Archive"
  description="Browse naval history topics, ships, battles, navies, and periods."
  pageType="topic-index"
>
  <main class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Topics</p>
      <h1>Browse by subject.</h1>
      <p class="lede">
        Topic pages will collect related videos and timestamped segment entries as the archive
        model fills in.
      </p>
    </section>

    <section class="placeholder-list" aria-label="Planned topic groups">
      <article>
        <span class="label">Ships</span>
        <h2>Classes, names, and design families</h2>
      </article>
      <article>
        <span class="label">Operations</span>
        <h2>Battles, campaigns, and deployments</h2>
      </article>
      <article>
        <span class="label">Navies</span>
        <h2>Countries, fleets, and institutions</h2>
      </article>
    </section>
  </main>
</BaseLayout>

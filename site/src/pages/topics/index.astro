---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { publicArchiveTopics } from "../../data/archive";
import { staticPageMetadata } from "../../../../src/site/page-metadata.js";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const featuredTopics = [...publicArchiveTopics]
  .sort((left, right) => right.segmentCount - left.segmentCount
    || right.videoCount - left.videoCount
    || left.title.localeCompare(right.title, "en", { sensitivity: "base" }))
  .slice(0, 12);
const videoCountLabel = (count: number) => count === 1 ? "1 video" : `${count} videos`;
const timeNoteCountLabel = (count: number) => count === 1 ? "1 time note" : `${count} time notes`;
const metadata = staticPageMetadata.topics;
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  pageType="topic-index"
>
  <main id="content" class="page-shell">
    <section class="section-heading">
      <p class="eyebrow">Topics</p>
      <h1>Follow a naval subject.</h1>
      <p class="lede">
        Trace ships, navies, battles, weapons, doctrine, policy, and strategy across
        related Dr. Clarke video moments.
      </p>
    </section>

    <section class="home-section" aria-labelledby="topic-finder-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Find a subject</p>
          <h2 id="topic-finder-heading">Search by ship, battle, navy, or idea</h2>
        </div>
      </div>
      <div class="search-panel">
        <form class="search-controls" role="search" action={`${baseUrl}search/`} method="get">
          <div class="search-control">
            <label for="topic-query">Search the study guide</label>
            <input
              class="search-input"
              id="topic-query"
              type="search"
              name="q"
              placeholder="Try destroyers, Jutland, logistics, or Royal Navy"
              autocomplete="off"
              aria-describedby="topic-query-help"
            />
            <p class="search-help" id="topic-query-help">
              Search topic guides alongside related video guides and precise time notes.
            </p>
          </div>
          <div><button class="primary-link" type="submit">Search the study guide</button></div>
        </form>
        <noscript>
          <p class="search-fallback">Search results need JavaScript. The complete A-Z topic directory below works without it.</p>
        </noscript>
      </div>
    </section>

    <section class="home-section" aria-labelledby="featured-topics-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Starting points</p>
          <h2 id="featured-topics-heading">Featured subjects</h2>
        </div>
      </div>
      <div class="topic-cloud" aria-label="Featured topics">
        {
          featuredTopics.map((topic) => (
            <a href={`${baseUrl}topics/${topic.slug}/`}>
              <strong>{topic.title}</strong>
              <span>{videoCountLabel(topic.videoCount)} · {timeNoteCountLabel(topic.segmentCount)}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="home-section" aria-labelledby="all-topics-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Complete directory</p>
          <h2 id="all-topics-heading">Browse every topic A-Z</h2>
        </div>
        <a class="secondary-link" href={`${baseUrl}topics/browse/`}>Open the complete topic directory</a>
      </div>
      <p>
        The paginated directory keeps all {publicArchiveTopics.length.toLocaleString("en-US")} covered subjects
        reachable through ordinary links without loading the full collection on one page.
      </p>
      <div class="action-row">
        <a class="primary-link" href={`${baseUrl}topics/browse/`}>Browse all topics</a>
      </div>
    </section>
  </main>
</BaseLayout>

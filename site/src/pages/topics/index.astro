---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveTopics } from "../../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Topics | Naval History with Dr. Alex Study Guide"
  description="Follow naval history subjects across Dr. Alex Clarke video timestamps."
  pageType="topic-index"
>
  <main id="content" class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Topics</p>
      <h1>Follow a naval subject.</h1>
      <p class="lede">
        Trace ships, navies, battles, weapons, doctrine, policy, and strategy across
        related Dr. Clarke timestamps.
      </p>
    </section>

    <section class="record-grid topics" aria-label="Topics">
      {
        archiveTopics.map((topic) => (
          <article class="topic-card">
            <span class="label">{topic.videoCount} videos · {topic.segmentCount} segments</span>
            <h2><a href={`${baseUrl}topics/${topic.slug}/`}>{topic.title}</a></h2>
            <p>{topic.summary}</p>
            {topic.aliases.length > 0 && <small>Also: {topic.aliases.join(", ")}</small>}
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

---
import type { GetStaticPaths, Page } from "astro";

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { topicsForBrowse, type ArchiveTopic } from "../../../data/archive";
import { buildTopicBrowseMetadata } from "../../../../../src/site/page-metadata.js";

export const getStaticPaths = (({ paginate }) => paginate(topicsForBrowse(), { pageSize: 48 })) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<ArchiveTopic> };
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const baseAwareUrl = (path: string | undefined): string | undefined => {
  if (!path) {
    return undefined;
  }
  const normalizedPath = path.endsWith("/") ? path : `${path}/`;
  return normalizedPath.startsWith(baseUrl)
    ? normalizedPath
    : `${baseUrl}${normalizedPath.replace(/^\/+/, "")}`;
};
const previousUrl = baseAwareUrl(page.url.prev);
const nextUrl = baseAwareUrl(page.url.next);
const videoCountLabel = (count: number) => count === 1 ? "1 video" : `${count} videos`;
const timeNoteCountLabel = (count: number) => count === 1 ? "1 time note" : `${count} time notes`;
const metadata = buildTopicBrowseMetadata(page.currentPage, page.lastPage);
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  pageType="topic-archive"
>
  <main id="content" class="page-shell">
    <section class="section-heading">
      <p class="eyebrow">Complete directory</p>
      <h1>Browse all topics A-Z: page {page.currentPage}.</h1>
      <p class="lede">
        Explore every covered naval-history subject through small, crawlable pages that work without JavaScript.
      </p>
      <div class="action-row">
        <a class="secondary-link" href={`${baseUrl}topics/`}>Return to the Topics finder</a>
      </div>
    </section>

    <nav class="archive-pagination" aria-label="Topic archive pages">
      <span>Page {page.currentPage} of {page.lastPage}</span>
      <div>
        {previousUrl ? <a class="secondary-link" href={previousUrl} rel="prev">Previous page</a> : <span aria-hidden="true"></span>}
        {nextUrl ? <a class="secondary-link" href={nextUrl} rel="next">Next page</a> : <span aria-hidden="true"></span>}
      </div>
    </nav>

    <section class="record-grid topics archive-record-grid" aria-label="Topics" data-pagefind-ignore>
      {
        page.data.map((topic) => (
          <article class="topic-card">
            <span class="label">{videoCountLabel(topic.videoCount)} · {timeNoteCountLabel(topic.segmentCount)}</span>
            <h2><a href={`${baseUrl}topics/${topic.slug}/`}>{topic.title}</a></h2>
            {topic.summary && <p>{topic.summary}</p>}
            {topic.aliases.length > 0 && <small>Also: {topic.aliases.join(", ")}</small>}
          </article>
        ))
      }
    </section>

    <nav class="archive-pagination archive-pagination-bottom" aria-label="More Topic archive pages">
      <span>Page {page.currentPage} of {page.lastPage}</span>
      <div>
        {previousUrl ? <a class="secondary-link" href={previousUrl} rel="prev">Previous page</a> : <span aria-hidden="true"></span>}
        {nextUrl ? <a class="secondary-link" href={nextUrl} rel="next">Next page</a> : <span aria-hidden="true"></span>}
      </div>
    </nav>
  </main>
</BaseLayout>

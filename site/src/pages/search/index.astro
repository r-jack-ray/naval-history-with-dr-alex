---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveTopics } from "../../data/archive";
import siteSearchUrl from "../../scripts/site-search.js?url";
import searchRankingUrl from "../../scripts/search-ranking.js?url";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const popularTopics = [...archiveTopics]
  .sort((left, right) => right.segmentCount - left.segmentCount || right.videoCount - left.videoCount)
  .slice(0, 12);
---

<BaseLayout
  title="Search | Naval History with Dr. Alex Study Guide"
  description="Search Dr. Alex Clarke videos by subject, topic, and video moment."
  pageType="search"
>
  <Fragment slot="head">
    <script src={siteSearchUrl} defer is:inline></script>
  </Fragment>

  <main id="content" class="page-shell">
    <section class="section-heading">
      <p class="eyebrow">Search</p>
      <h1>Search ships, navies, battles, and ideas.</h1>
      <p class="lede">
        Search the time notes, topic pages, and video titles to find the
        Dr. Clarke moment that matches what you want to learn.
      </p>
    </section>

    <section class="search-panel search-experience" aria-label="Site search">
      <form
        class="search-controls site-search-form"
        role="search"
        data-site-search-form
        data-pagefind-url={`${baseUrl}pagefind/pagefind.js`}
        data-pagefind-base={`${baseUrl}pagefind/`}
        data-site-base={baseUrl}
        data-search-ranking-url={searchRankingUrl}
        data-topic-lookup-url={`${baseUrl}search-topic-lookup.json`}
      >
        <div class="search-control">
          <label for="site-search-input">Search the study guide</label>
          <div class="search-input-shell">
            <input
              class="search-input"
              id="site-search-input"
              type="search"
              name="q"
              placeholder="Try Royal Navy, destroyers, Jutland, carriers, logistics"
              autocomplete="off"
              aria-controls="site-search-results"
              aria-describedby="site-search-help site-search-status"
              data-site-search-input
            />
            <button class="search-clear-button" type="button" data-site-search-clear hidden>Clear</button>
          </div>
          <p class="search-help" id="site-search-help">
            Find video guides, time notes, and topics by ship, navy, battle, weapon, doctrine, or strategy.
          </p>
        </div>
      </form>
      <p class="search-status search-feedback" id="site-search-status" data-site-search-status aria-live="polite" aria-atomic="true">
        Type a subject to search the study guide.
      </p>
      <div
        class="record-grid search-results"
        id="site-search-results"
        data-site-search-results
        aria-label="Search results"
        aria-busy="false"
      ></div>
      <button class="show-more-button" type="button" data-site-search-more hidden>Show more results</button>
      <noscript>
        <p class="search-fallback">Search needs JavaScript. You can still browse the topic directory and video guides.</p>
      </noscript>
    </section>

    <section class="home-section" aria-labelledby="popular-topics-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Topics</p>
          <h2 id="popular-topics-heading">Popular subjects</h2>
        </div>
        <a class="secondary-link" href={`${baseUrl}topics/`}>Browse all topics</a>
      </div>
      <div class="topic-cloud" aria-label="Common searches">
        {
          popularTopics.map((topic) => (
            <a href={`${baseUrl}topics/${topic.slug}/`}>
              <strong>{topic.title}</strong>
              <span>{topic.videoCount} videos · {topic.segmentCount} time notes</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveTopics } from "../../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const popularTopics = [...archiveTopics]
  .sort((left, right) => right.segmentCount - left.segmentCount || right.videoCount - left.videoCount)
  .slice(0, 8);
---

<BaseLayout
  title="Search | Naval History with Dr. Alex Archive"
  description="Search Naval History with Dr. Alex videos, topics, and timestamped notes."
  pageType="search"
>
  <Fragment slot="head">
    <link rel="stylesheet" href={`${baseUrl}pagefind/pagefind-component-ui.css`} />
    <script type="module" src={`${baseUrl}pagefind/pagefind-component-ui.js`} is:inline></script>
  </Fragment>

  <main id="content" class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Search</p>
      <h1>Find videos, topics, and segment notes.</h1>
      <p class="lede">
        Search across videos, timestamped notes, topic pages, and source passages.
      </p>
    </section>

    <section class="search-panel" aria-label="Site search">
      <pagefind-config bundle-path={`${baseUrl}pagefind/`} base-url={baseUrl} faceted></pagefind-config>
      <pagefind-input placeholder="Search ships, battles, navies, and questions"></pagefind-input>
      <pagefind-filter-pane show-empty="false" sort="alphabetical" open="type,kind,topic,video"></pagefind-filter-pane>
      <pagefind-summary default-message="Search videos, timestamped notes, and topics."></pagefind-summary>
      <pagefind-results show-images="false"></pagefind-results>
    </section>

    <section class="home-section" aria-labelledby="popular-topics-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Topics</p>
          <h2 id="popular-topics-heading">Common searches</h2>
        </div>
      </div>
      <div class="topic-cloud" aria-label="Common searches">
        {
          popularTopics.map((topic) => (
            <a href={`${baseUrl}topics/${topic.slug}/`}>
              <strong>{topic.title}</strong>
              <span>{topic.videoCount} videos · {topic.segmentCount} segments</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

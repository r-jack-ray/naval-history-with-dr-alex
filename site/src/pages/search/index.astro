---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveSegments, archiveTopics, archiveVideos } from "../../data/archive";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const popularTopics = [...archiveTopics]
  .sort((left, right) => right.segmentCount - left.segmentCount || right.videoCount - left.videoCount)
  .slice(0, 8);
const timeNoteCountLabel = (count: number) => count === 1 ? "1 time note" : `${count} time notes`;
const searchItems = [
  ...archiveSegments.map((segment) => ({
    type: "Time note",
    title: segment.title,
    url: `${baseUrl}segments/${segment.slug}/`,
    label: `${segment.kindLabel} · ${segment.start}`,
    meta: segment.videoTitle,
    summary: segment.summary,
    topics: segment.topics.map((topic) => topic.title),
    text: [
      segment.title,
      segment.kindLabel,
      segment.start,
      segment.videoTitle,
      segment.summary,
      segment.body,
      segment.question,
      segment.answerShort,
      ...segment.topics.map((topic) => topic.title),
    ].filter(Boolean).join(" "),
  })),
  ...archiveVideos.map((video) => ({
    type: "Video guide",
    title: video.title,
    url: `${baseUrl}videos/${video.slug}/`,
    label: video.sourceType,
    meta: `${video.publishedLabel} · ${video.durationLabel} · ${timeNoteCountLabel(video.segmentSlugs.length)}`,
    summary:
      video.topics.length > 0
        ? `Covers ${video.topics.slice(0, 4).map((topic) => topic.title).join(", ")}.`
        : "Open this video guide to see available time notes.",
    topics: video.topics.map((topic) => topic.title),
    text: [
      video.title,
      video.sourceType,
      video.publishedLabel,
      video.durationLabel,
      ...video.topics.map((topic) => topic.title),
    ].join(" "),
  })),
  ...archiveTopics.map((topic) => ({
    type: "Topic",
    title: topic.title,
    url: `${baseUrl}topics/${topic.slug}/`,
    label: "Topic",
    meta: `${topic.videoCount} videos · ${topic.segmentCount} segments`,
    summary: topic.summary,
    topics: topic.aliases,
    text: [topic.title, topic.summary, ...topic.aliases].join(" "),
  })),
];
const searchDataJson = JSON.stringify(searchItems).replace(/</g, "\\u003c");
---

<BaseLayout
  title="Search | Naval History with Dr. Alex Study Guide"
  description="Search Dr. Alex Clarke videos by subject, topic, and video moment."
  pageType="search"
>
  <Fragment slot="head">
    <script type="application/json" id="site-search-data" set:html={searchDataJson} is:inline></script>
    <script src={`${baseUrl}scripts/site-search.js`} defer is:inline></script>
  </Fragment>

  <main id="content" class="page-shell" data-pagefind-body>
    <section class="section-heading">
      <p class="eyebrow">Search</p>
      <h1>Search ships, navies, battles, and ideas.</h1>
      <p class="lede">
        Search the time notes, topic pages, and video titles to find the
        Dr. Clarke moment that matches what you want to learn.
      </p>
    </section>

    <section class="search-panel" aria-label="Site search">
      <form class="site-search-form" role="search" data-site-search-form>
        <label for="site-search-input">Search the guide</label>
        <div class="site-search-row">
          <input
            id="site-search-input"
            type="search"
            name="q"
            placeholder="Try Royal Navy, destroyers, Jutland, carriers, logistics"
            autocomplete="off"
            data-site-search-input
          />
          <button type="button" data-site-search-clear hidden>Clear</button>
        </div>
        <p class="search-help">
          Search video guides, time notes, topics, ship classes, navies, battles, weapons, doctrine, and strategy.
        </p>
      </form>
      <p class="search-status" data-site-search-status aria-live="polite">
        Type a subject to search the study guide.
      </p>
      <div class="record-grid search-results" data-site-search-results></div>
    </section>

    <section class="home-section" aria-labelledby="popular-topics-heading">
      <div class="section-title-row">
        <div>
          <p class="eyebrow">Topics</p>
          <h2 id="popular-topics-heading">Starting points</h2>
        </div>
      </div>
      <div class="topic-cloud" aria-label="Common searches">
        {
          popularTopics.map((topic) => (
            <a href={`${baseUrl}topics/${topic.slug}/`}>
              <strong>{topic.title}</strong>
              <span>{topic.videoCount} videos · {topic.segmentCount} segments</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

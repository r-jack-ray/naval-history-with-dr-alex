---
interface Props {
  canonicalTitle: string;
  canonicalUrl: string;
}

const { canonicalTitle, canonicalUrl } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{`Moved to ${canonicalTitle} | Naval History with Dr. Alex Study Guide`}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0; url=${canonicalUrl}`} />
  </head>
  <body>
    <main>
      <p>This topic has moved to <a href={canonicalUrl}>{canonicalTitle}</a>.</p>
    </main>
  </body>
</html>

---
interface Props {
  title: string;
  description: string;
  pageType: string;
}

const { title, description, pageType } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta data-pagefind-meta="type[content]" content={pageType} />
    <meta data-pagefind-filter="type[content]" content={pageType} />
    <link rel="stylesheet" href={`${baseUrl}styles/site.css`} />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={baseUrl}>Naval History with Dr. Alex</a>
      <nav class="nav-links" aria-label="Primary">
        <a href={`${baseUrl}videos/`}>Videos</a>
        <a href={`${baseUrl}topics/`}>Topics</a>
        <a href={`${baseUrl}search/`}>Search</a>
      </nav>
    </header>
    <slot />
  </body>
</html>

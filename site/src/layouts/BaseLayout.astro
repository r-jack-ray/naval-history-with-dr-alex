---
import "../styles/site.css";
import themeInteractionUrl from "../scripts/theme-interaction.js?url&no-inline";
import { pageIndexingForPathname } from "../data/page-indexing.js";

interface Props {
  title: string;
  description: string;
  pageType: string;
  socialType?: "website" | "video.other";
  socialImageUrl?: string;
  socialImageAlt?: string;
}

const {
  title,
  description,
  pageType,
  socialType = "website",
  socialImageUrl,
  socialImageAlt,
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const currentPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`;
const indexing = pageIndexingForPathname(currentPath, baseUrl);
if (Astro.site === undefined) {
  throw new Error("Astro site configuration is required to generate canonical URLs.");
}
const canonicalUrl = new URL(currentPath, Astro.site);
const sitemapUrl = new URL(`${baseUrl}sitemap-index.xml`, Astro.site);
let socialImage: { url: string; alt: string } | undefined;
if (socialImageUrl !== undefined) {
  const alt = socialImageAlt?.trim();
  if (alt === undefined || alt.length === 0) {
    throw new Error("A meaningful socialImageAlt is required when socialImageUrl is provided.");
  }
  const url = new URL(socialImageUrl);
  if (url.protocol !== "https:" && url.protocol !== "http:") {
    throw new Error(`Social image URL must use HTTP or HTTPS: ${socialImageUrl}`);
  }
  socialImage = { url: url.href, alt };
} else if (socialImageAlt !== undefined) {
  throw new Error("socialImageUrl is required when socialImageAlt is provided.");
}
const navItems = [
  { label: "Videos", path: "videos/" },
  { label: "Time Notes", path: "segments/" },
  { label: "Topics", path: "topics/" },
  { label: "Search", path: "search/" },
];
const isActivePath = (path: string) => currentPath.startsWith(`${baseUrl}${path}`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {indexing === "noindex" && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="sitemap" type="application/xml" href={sitemapUrl.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:type" content={socialType} />
    {
      socialImage && (
        <>
          <meta property="og:image" content={socialImage.url} />
          <meta property="og:image:alt" content={socialImage.alt} />
        </>
      )
    }
    <meta name="twitter:card" content={socialImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {
      socialImage && (
        <>
          <meta name="twitter:image" content={socialImage.url} />
          <meta name="twitter:image:alt" content={socialImage.alt} />
        </>
      )
    }
    <link rel="icon" type="image/png" sizes="160x160" href={`${baseUrl}favicon.png`} />
    <meta data-pagefind-meta="type[content]" content={pageType} />
    <meta data-pagefind-filter="type[content]" content={pageType} />
    <script is:inline>
      (() => {
        const storageKey = "naval-history-theme";
        const choices = new Set(["light", "dark", "bruships", "system"]);
        const savedChoice = (() => {
          try {
            return localStorage.getItem(storageKey) || "";
          } catch {
            return "";
          }
        })();
        const themeChoice = choices.has(savedChoice) ? savedChoice : "system";
        const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const appliedTheme = themeChoice === "system" ? (systemPrefersDark ? "dark" : "light") : themeChoice;

        document.documentElement.dataset.theme = appliedTheme;
        document.documentElement.dataset.themeChoice = themeChoice;
        document.documentElement.style.colorScheme = appliedTheme === "bruships" ? "dark" : appliedTheme;
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href={baseUrl}>
          <span>Naval History</span>
          <small>with Dr. Alex</small>
        </a>
        <div class="header-controls">
          <nav class="nav-links" aria-label="Primary">
            {
              navItems.map((item) => (
                <a href={`${baseUrl}${item.path}`} aria-current={isActivePath(item.path) ? "page" : undefined}>
                  {item.label}
                </a>
              ))
            }
          </nav>
          <div class="theme-switcher" role="group" aria-label="Color theme">
            <button type="button" data-theme-choice="light" aria-label="Use light theme" aria-pressed="false">
              <span class="theme-icon theme-icon-light" aria-hidden="true"></span>
              <span class="theme-label">Light</span>
            </button>
            <button type="button" data-theme-choice="dark" aria-label="Use dark theme" aria-pressed="false">
              <span class="theme-icon theme-icon-dark" aria-hidden="true"></span>
              <span class="theme-label">Dark</span>
            </button>
            <button type="button" data-theme-choice="bruships" aria-label="Use Bruships theme" aria-pressed="false">
              <span class="theme-icon theme-icon-bruships" aria-hidden="true"></span>
              <span class="theme-label">Bruships</span>
            </button>
            <button type="button" data-theme-choice="system" aria-label="Use system theme" aria-pressed="false">
              <span class="theme-icon theme-icon-system" aria-hidden="true"></span>
              <span class="theme-label">System</span>
            </button>
          </div>
        </div>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div>
        <strong>Naval History with Dr. Alex Study Guide</strong>
        <span>Searchable video guides and time notes for learning naval history and how navies work.</span>
      </div>
      <nav aria-label="Footer">
        <a href={`${baseUrl}videos/`}>Videos</a>
        <a href={`${baseUrl}segments/`}>Time Notes</a>
        <a href={`${baseUrl}topics/`}>Topics</a>
        <a href={`${baseUrl}search/`}>Search</a>
      </nav>
    </footer>
    <script src={themeInteractionUrl} defer is:inline data-theme-interaction></script>
  </body>
</html>

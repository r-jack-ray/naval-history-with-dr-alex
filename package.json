{
  "name": "naval-history-with-dr-alex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static reference archive tooling for Dr. Alex Clarke's naval history videos.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "audit:site-content": "npm run build && node dist/scripts/audit-site-content.js",
    "check": "npm run check:types && npm test",
    "check:types": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "convert:transcript-json": "npm run build && node dist/scripts/convert-transcript-json.js",
    "extract:saved-channel-html": "npm run build && node dist/scripts/extract-saved-channel-html.js",
    "extract:live-streams-html": "npm run build && node dist/scripts/extract-live-streams-html.js",
    "extract:videos-html": "npm run extract:saved-channel-html -- --tab videos",
    "fetch:transcript": "npm run build && node dist/scripts/get-video-transcript.js",
    "fetch:transcripts": "npm run build && node dist/scripts/fetch-transcript-batch.js",
    "fetch:transcripts:retry": "npm run fetch:transcripts -- --retry-failed",
    "fetch:video-metadata": "npm run build && node dist/scripts/fetch-video-metadata.js --api-key-file reports/youtube-api-key.txt",
    "fetch:video-links": "npm run build && node dist/scripts/get-channel-video-links.js --api-key-file reports/youtube-api-key.txt",
    "generate:site-data": "npm run build && node dist/scripts/generate-site-data.js",
    "merge:video-links": "npm run build && node dist/scripts/merge-channel-video-links.js",
    "site:build": "npm run generate:site-data && astro build && pagefind --site site/dist",
    "site:check": "npm run generate:site-data && astro check --tsconfig tsconfig.astro.json",
    "site:dev": "astro dev",
    "site:preview": "astro preview",
    "store:transcript-json": "npm run build && node dist/scripts/store-transcript-json.js",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "preaudit:lighthouse:home": "node -e \"require('fs').mkdirSync('reports/lighthouse', { recursive: true })\"",
    "audit:lighthouse:home": "lighthouse https://r-jack-ray.github.io/naval-history-with-dr-alex/ --output=html --output=json --output-path=reports/lighthouse/home --chrome-flags=\"--headless\"",
    "preaudit:lighthouse:local": "node -e \"require('fs').mkdirSync('reports/lighthouse', { recursive: true })\"",
    "audit:lighthouse:local": "lighthouse http://127.0.0.1:4321/naval-history-with-dr-alex/ --output=html --output=json --output-path=reports/lighthouse/local-home --chrome-flags=\"--headless\""
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.10.0",
    "astro": "^7.0.6",
    "lighthouse": "^13.4.0",
    "pagefind": "^1.5.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "googleapis": "^173.0.0",
    "youtube-transcript-plus": "^2.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}

{
  "name": "naval-history-with-dr-alex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static reference archive tooling for Dr. Alex Clarke's naval history videos.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run check:types && npm test",
    "check:types": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "convert:transcript-json": "npm run build && node dist/scripts/convert-transcript-json.js",
    "fetch:transcript": "npm run build && node dist/scripts/get-video-transcript.js",
    "fetch:video-links": "npm run build && node dist/scripts/get-channel-video-links.js",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "youtubei.js": "^17.2.0"
  }
}
